# Configuración de Base de Datos
DATABASE_URL=sqlite:///./sql_app.db
# Para MySQL: DATABASE_URL=mysql+mysqlconnector://usuario:password@localhost/registro_viajes

# Configuración de Email (SMTP)
# Usa las credenciales de tu servidor SMTP (Gmail, Outlook, servidor corporativo, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_password_o_app_password
SMTP_FROM_EMAIL=tu_email@gmail.com

# Email de destino para reportes diarios
REPORT_EMAIL=oscar@forestalgaruhape.com.ar

# Alertas inmediatas por errores criticos de API/guardado (produccion)
ALERT_EMAIL=oscar@forestalgaruhape.com.ar
ALERT_COOLDOWN_MINUTES=15
ENABLE_ERROR_ALERT_EMAILS=true

# Si tu tabla movimientocombustible exige proveedor_id NOT NULL
# configura un proveedor por defecto para cargas de combustible.
DEFAULT_FUEL_PROVEEDOR_ID=

# Hora de envío del reporte diario (formato HH:MM, 24 horas)
DAILY_REPORT_TIME=08:00

# Configuraciones adicionales
APP_ENV=production
DEBUG=false

# Sentry configuration (add your DSN in deployment environment, do NOT commit secrets)
SENTRY_DSN=https://SU_DSN
SENTRY_ENV=environment_name
SENTRY_RELEASE=release_version
SENTRY_SEND_DEFAULT_PII=default_value

# Autenticacion JWT
# En produccion, usar una clave larga y privada. No commitear secretos reales.
JWT_SECRET_KEY=generar_una_clave_larga_aleatoria
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720
# compat: emite/acepta JWT sin bloquear rutas viejas; strict: exigir token en rutas protegidas.
AUTH_ENFORCEMENT_MODE=compat

# Database connection pool tuning (use when DATABASE_URL points to MySQL)
# These are safe example defaults — tune them for your deployment and workload.
# Do NOT store DB credentials here; keep `DATABASE_URL` with credentials in your
# deployment environment or secret manager. The app reads these values and uses
# them when creating the SQLAlchemy engine.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=280
DB_POOL_TIMEOUT=30
